# Data — never commit raw or processed data
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Models
models/*
!models/.gitkeep

# Reports figures
reports/figures/*
!reports/figures/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Environment files
.env
*.env

# IDE
.vscode/
.idea/
*.swp

# Claude / AI tooling
.claude/

# OS
.DS_Store
Thumbs.db

# Legacy archive (kept locally, not committed)
legacy/

# Executed notebook snapshots
notebooks/executed/
*_executed.ipynb
